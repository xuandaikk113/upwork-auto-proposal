# n8n Webhook URL (auto-generated by n8n)
# After importing the workflow, copy the webhook URL from n8n
# and paste it into the Upwork Job Scraper Chrome extension settings
# Example: http://localhost:5678/webhook/upwork-jobs
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/upwork-jobs

# Google Sheets
# Create a sheet and get the ID from the URL
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_CREDENTIALS_FILE=/data/google-credentials.json

# LM Studio (running on host machine)
# Default LM Studio port is 1234
LLM_HOST=http://host.docker.internal:1234
LLM_MODEL=your-model-name

# Telegram Notifications
# Create a bot via @BotFather and get your chat ID
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Notification Threshold (1-10)
# Jobs scoring >= this value will trigger Telegram notification
NOTIFY_THRESHOLD=9

# n8n Authentication
N8N_USER=admin
N8N_PASSWORD=change-this-secure-password
