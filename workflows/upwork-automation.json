    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 3
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Finalize Proposal').item.json.score }}",
                    "rightValue": "={{ Number($env.NOTIFY_THRESHOLD) || 9 }}",
                    "operator": {
                      "type": "number",
                      "operation": "gte"
                    },
                    "id": "notify-1"
                  }
                ],
                "combinator": "and"
