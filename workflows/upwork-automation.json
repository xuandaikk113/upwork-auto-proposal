    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LLM_HOST }}/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.LLM_MODEL }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a job scoring assistant. Score this Upwork job based on how well it matches the candidate's resume and portfolio. Output ONLY valid JSON.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"## Job Details\\nTitle: {{ $('Extract Job Fields').item.json.title }}\\nDescription: {{ $('Extract Job Fields').item.json.description }}\\nBudget: {{ $('Extract Job Fields').item.json.budget }}\\nSkills: {{ $('Extract Job Fields').item.json.skills }}\\nExperience Level: {{ $('Extract Job Fields').item.json.experience_level }}\\n\\n## Resume\\n(AI Engineer with 4+ years experience in LLM, Computer Vision, Python, Django, FastAPI, vLLM, PyTorch)\\n\\n## Instructions\\nScore this job 1-10 based on fit. Output JSON with: score (integer 1-10), match_reasons (array of strings), red_flags (array of strings), suggested_rate (string), estimated_effort (string), questions_for_client (array of strings).\"\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 1000\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1760, -100],
      "id": "llm-score",
      "name": "LLM - Score Job"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "score-1",
              "name": "llm_response",
              "value": "={{ $json.choices[0].message.content }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1980, -100],
      "id": "parse-score",
      "name": "Parse Score Response"
    },
    {
      "parameters": {
        "jsCode": "// Parse the LLM response and extract scoring data\nconst llmResponse = $input.first().json.llm_response;\nconst jobData = $('Extract Job Fields').first().json;\n\nlet scoreData;\ntry {\n  // Try to parse JSON from the response\n  const jsonMatch = llmResponse.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    scoreData = JSON.parse(jsonMatch[0]);\n  } else {\n    scoreData = JSON.parse(llmResponse);\n  }\n} catch (e) {\n  // Default values if parsing fails\n  scoreData = {\n    score: 5,\n    match_reasons: ['Unable to parse LLM response'],\n    red_flags: [],\n    suggested_rate: 'N/A',\n    estimated_effort: 'N/A',\n    questions_for_client: []\n  };\n}\n\nreturn {\n  json: {\n    ...jobData,\n    score: scoreData.score || 5,\n    match_reasons: Array.isArray(scoreData.match_reasons) ? scoreData.match_reasons.join('; ') : scoreData.match_reasons,\n    red_flags: Array.isArray(scoreData.red_flags) ? scoreData.red_flags.join('; ') : scoreData.red_flags,\n    suggested_rate: scoreData.suggested_rate || 'N/A',\n    estimated_effort: scoreData.estimated_effort || 'N/A',\n    questions_for_client: Array.isArray(scoreData.questions_for_client) ? scoreData.questions_for_client.join('; ') : scoreData.questions_for_client\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, -100],
      "id": "code-parse",
      "name": "Merge Job + Score"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LLM_HOST }}/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.LLM_MODEL }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a solution architect. Generate a Mermaid.js flowchart diagram showing the proposed solution architecture. Output ONLY the Mermaid code starting with 'graph' or 'flowchart', no markdown fences.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Create a solution architecture diagram for this project:\\n\\nTitle: {{ $json.title }}\\nDescription: {{ $json.description }}\\nSkills needed: {{ $json.skills }}\"\n    }\n  ],\n  \"temperature\": 0.5,\n  \"max_tokens\": 800\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2420, -100],
      "id": "llm-mermaid",
      "name": "LLM - Generate Mermaid"
    },
    {
      "parameters": {
        "jsCode": "// Extract Mermaid code and create image URL\nconst response = $input.first().json;\nconst jobData = $('Merge Job + Score').first().json;\n\nlet mermaidCode = response.choices[0].message.content;\n\n// Clean up the mermaid code\nmermaidCode = mermaidCode.replace(/```mermaid\\n?/g, '').replace(/```\\n?/g, '').trim();\n\n// Ensure it starts with graph or flowchart\nif (!mermaidCode.startsWith('graph') && !mermaidCode.startsWith('flowchart')) {\n  mermaidCode = 'graph TD\\n  A[Client] --> B[Solution]\\n  B --> C[Delivery]';\n}\n\n// Create mermaid.ink URL\nconst base64Code = Buffer.from(mermaidCode).toString('base64');\nconst mermaidImageUrl = `https://mermaid.ink/img/${base64Code}`;\n\nreturn {\n  json: {\n    ...jobData,\n    mermaid_code: mermaidCode,\n    mermaid_image_url: mermaidImageUrl\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, -100],
      "id": "code-mermaid",
      "name": "Create Mermaid Image URL"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LLM_HOST }}/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.LLM_MODEL }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You write Upwork proposals. Be casual, confident, and concise. No flowery language or emojis. Under 150 words. Always include $$$ as a placeholder (exactly three dollar signs) where the portfolio link will go.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a cover letter for this job:\\n\\nTitle: {{ $json.title }}\\nDescription: {{ $json.description }}\\n\\nAbout me: AI Engineer with 4+ years experience. Expert in LLM, RAG, Computer Vision, Python, vLLM, PyTorch. Built enterprise AI search systems, industrial CV monitoring, real-time analytics.\\n\\nUse this template style:\\nHi, I do [relevant thing] all the time.\\nSo confident I'm the right fit that I created a solution diagram + proposal: $$$\\n\\n[Brief relevant background]\\n[Specific value you bring]\\n\\nHappy to discuss—just respond to this proposal.\\nThank you!\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 500\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2860, -100],
      "id": "llm-proposal",
      "name": "LLM - Generate Proposal"
    },
    {
      "parameters": {
        "jsCode": "// Extract proposal and prepare final data\nconst response = $input.first().json;\nconst jobData = $('Create Mermaid Image URL').first().json;\n\nlet proposal = response.choices[0].message.content;\n\n// For now, replace $$$ with mermaid image URL (later will be Google Doc URL)\nconst proposalWithLink = proposal.replace('$$$', jobData.mermaid_image_url);\n\nreturn {\n  json: {\n    ...jobData,\n    proposal_draft: proposal,\n    proposal_with_link: proposalWithLink\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3080, -100],
      "id": "code-proposal",
      "name": "Finalize Proposal"
    },
